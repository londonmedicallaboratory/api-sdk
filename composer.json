{
    "name": "londonmedicallaboratory/api-sdk",
    "type": "symfony-bundle",
    "license": "MIT",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "keywords": [
        "symfony-ux"
    ],
    "authors": [
        {
            "name": "zmitic",
            "email": "mitke013@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "symfony/http-kernel": "^6|^7",
        "symfony/http-client": "^6|^7",
        "endroid/installer": "^1.4",
        "londonmedicallaboratory/view-bundle": "dev-master",
        "react/http": "^1.7",
        "brick/money": "^0.5.3",
        "symfony/twig-bundle": "^6|^7",
        "omnipay/sagepay": "dev-feature/pi-protocol-4",
        "symfony/intl": "^6|^7",
        "twig/extra-bundle": "^3.4",
        "twig/string-extra": "^3.4",
        "symfony/framework-bundle": "^6|^7",
        "symfony/form": "^6|^7",
        "webmozart/assert": "^1.11",
        "symfony/security-bundle": "^6|^7",
        "nyholm/psr7": "^1.7",
        "php-http/httplug": "^2.4",
        "react/async": "^4.2"
    },
    "require-dev": {
        "roave/security-advisories": "dev-latest",
        "symfony/phpunit-bridge": "^6|^7",
        "symfony/yaml": "^6|^7",
        "symfony/stopwatch": "^6|^7",
        "symfony/web-profiler-bundle": "^6|^7"
    },
    "repositories": [
        {
            "type": "github",
            "url": "https://github.com/londonmedicallaboratory/view-bundle.git"
        },
        {
            "type": "github",
            "url": "https://github.com/benjam-es/omnipay-sagepay"
        }
    ],
    "autoload": {
        "files": [
            "src/functions.php"
        ],
        "psr-4": {
            "LML\\SDK\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LML\\SDK\\Tests\\": "tests",
            "LML\\SDK\\Fixture\\": "tests\\fixtures"
        }
    },
    "extra": {
        "symfony": {
            "allow-contrib": true,
            "require": "^7"
        }
    },
    "config": {
        "allow-plugins": {
            "endroid/installer": true,
            "php-http/discovery": true
        }
    }
}
